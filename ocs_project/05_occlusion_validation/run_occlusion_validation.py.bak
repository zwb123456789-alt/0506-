OUT_DIR = OUTPUT_ROOT / RUN_ID
MODEL_DIR = OUT_DIR / "models"
FIG_DIR = OUT_DIR / "figures"

UP = np.array([0.0, 0.0, 1.0], dtype=float)
PLUS_Y = np.array([0.0, 1.0, 0.0], dtype=float)
PLUS_X = np.array([1.0, 0.0, 0.0], dtype=float)


